# Smart Attendance System - Environment Variables
# Copy this file to .env and update values

# Flask
SECRET_KEY=your-super-secret-key-here
FLASK_ENV=development

# Database (default: SQLite, change for PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost/smartattendance
DATABASE_URL=sqlite:///smartattendance.db

# Email (Brevo / Sendinblue)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-user@smtp-brevo.com
BREVO_SMTP_PASS=your-brevo-smtp-password
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=SmartAttendance

# Face Recognition (DeepFace ArcFace)
# DEEPFACE_MODEL=ArcFace
# FACE_SIMILARITY_THRESHOLD=0.5
FACE_TOLERANCE=0.5

# Attendance
ATTENDANCE_THRESHOLD=75
DEFAULT_GRACE_PERIOD_MINUTES=10# Timezone (default: Indian Standard Time)
# APP_TIMEZONE=Asia/Kolkata
